# ═══════════════════════════════════════════════════════════════
# TTAI — Production Environment Variables (GCP)
# ═══════════════════════════════════════════════════════════════
# Copy to .env.production and fill in values.
# For Cloud Run: use Secret Manager for sensitive values.

# App
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://ttai-web-xxxxx-el.a.run.app
PORT=3000

# Gemini AI (store in Secret Manager as GEMINI_API_KEY)
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloud Storage (for temple data persistence)
GCS_BUCKET_NAME=your-project-id-ttai-data

# Optional: Database (when Dharma Stack connectors go live)
# TTAI_DB_HOST=
# TTAI_DB_PORT=3306
# TTAI_DB_NAME=ttai
# TTAI_DB_USER=
# TTAI_DB_PASSWORD=
